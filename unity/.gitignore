# This .gitignore is scoped to the Unity project directory.
# Root-level repo ignores handle Blender, Python, OS, and shared editor state.
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

# Unity can import Blender files directly; Blender save-version backups are noise.
*.blend[0-9]*
*.blend@
*.blend~

# MemoryCaptures can get excessive in size and may contain sensitive data.
/[Mm]emoryCaptures/

# Recordings can get excessive in size.
/[Rr]ecordings/

# Autogenerated Rider plugin and personal settings.
/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user

# Visual Studio cache directory.
.vs/

# Gradle cache directory.
.gradle/

# Autogenerated VS/MD/Consulo solution and project files.
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity generated meta files for generated assemblies/debug symbols.
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity generated crash files.
sysinfo.txt
mono_crash.*
*.stackdump

# Builds and exported packages.
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file.
crashlytics-build.properties

# TestRunner generated files.
InitTestScene*.unity*

# Addressables default ignores, before user customizations.
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files.
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes and dependency caches in Assets.
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
/[Aa]ssets/[Ss]ceneDependencyCache*

# Repo-generated prototype scene. Source of truth is PrototypeSceneBuilder.cs.
/Assets/_Game/Scenes/Prototype01.unity
/Assets/_Game/Scenes/Prototype01.unity.meta
/Assets/_Game/Scenes/Map2Prototype.unity
/Assets/_Game/Scenes/Map2Prototype.unity.meta
/Assets/_Game/Scenes/Prototype01.unity.meta
